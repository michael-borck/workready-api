# WorkReady Simulation API — Environment Configuration
# Copy to .env and fill in values

# --- LLM Provider ---
# Options: stub, ollama, anthropic, openrouter
LLM_PROVIDER=stub

# --- Model ---
# Model name (interpreted by the chosen provider)
# ollama:     llama3.2, mistral, etc.
# anthropic:  claude-sonnet-4-20250514, claude-haiku-4-5-20251001, etc.
# openrouter: anthropic/claude-sonnet-4, google/gemini-2.5-flash, etc.
LLM_MODEL=llama3.2

# --- Ollama (local or remote) ---
OLLAMA_BASE_URL=http://localhost:11434
# For remote Ollama behind auth (e.g. via Tailscale/Caddy):
OLLAMA_API_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- OpenRouter ---
OPENROUTER_API_KEY=

# --- Database ---
# SQLite file path (inside the container, /data is the mounted volume)
WORKREADY_DB=/data/workready.db

# --- Job Data ---
# Path to directory containing job exports.
# Leave commented out to use the default — bundled jobs at /app/jobs.
# Only override if you want to mount a custom jobs directory.
# DO NOT set this to /data/jobs — that path is shadowed by the bind mount.
# SITES_DIR=/app/jobs

# --- Stage 3 polish: interview booking and timing ---

# Enable interview booking flow (preference-based slot picker, late forfeit)
# Defaults to false so dev/testing works without scheduling pressure
INTERVIEW_BOOKING_ENABLED=false

# Business hours (24-hour, in TIMEZONE local time)
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
BUSINESS_DAYS=1,2,3,4,5
TIMEZONE=Australia/Perth

# Slot generation
SLOT_DURATION_MINUTES=30
SLOTS_OFFERED=4
EARLIEST_BOOKING_HOURS=2
LATEST_BOOKING_DAYS=14

# Lateness and rejection
LATE_GRACE_MINUTES=5
MAX_MISSED_INTERVIEWS=3

# Reschedule limit (separate from misses)
# - hard mode: at limit, reschedule attempts are blocked (default)
# - soft mode: counter tracked but not enforced (effectively unlimited)
MAX_RESCHEDULES=1
RESCHEDULE_LIMIT_MODE=hard

# Public holidays — comma-separated YYYY-MM-DD strings
# Leave commented out to use the bundled WA 2026-2027 default list
# PUBLIC_HOLIDAYS=2026-12-25,2026-12-26,...

# Feedback delays — defaults to instant (0). Set to 30+ for realism.
# Jitter randomises within ± the specified minutes for variability.
#
# Philosophy: real employers don't reply to applications in 3 seconds.
# A small delay (plus jitter) breaks the "tick-the-box" feel and forces
# students to live with uncertainty, which is the actual skill. All of
# these are lazy-evaluated — a job/message is just hidden until its
# deliver_at timestamp passes. No background workers.
#
# Suggested "authentic" values (enable once you've validated the flow):
#   RESUME_FEEDBACK_DELAY_MINUTES=180          # ~3 hours
#   RESUME_FEEDBACK_DELAY_JITTER_MINUTES=120   # ± 2 hours
#   INTERVIEW_FEEDBACK_DELAY_MINUTES=60        # ~1 hour after the interview
#   INTERVIEW_FEEDBACK_DELAY_JITTER_MINUTES=30
RESUME_FEEDBACK_DELAY_MINUTES=0
RESUME_FEEDBACK_DELAY_JITTER_MINUTES=0
INTERVIEW_INVITATION_DELAY_MINUTES=0
INTERVIEW_FEEDBACK_DELAY_MINUTES=0
INTERVIEW_FEEDBACK_DELAY_JITTER_MINUTES=0

# --- Stage 4: Work tasks ---

# Number of tasks the mentor assigns per internship (progressively harder:
# easy → medium → hard). Must be ≤ the number of task_templates available
# per company. Default 3.
TASKS_PER_STUDENT=3

# Deadline per task (days from the moment the task becomes visible).
# Late submissions are allowed and the mentor may remark on the lateness
# in their feedback — nothing hard-fails.
TASK_DEADLINE_DAYS=7

# Task pacing. After a student submits task N:
#   1. After TASK_NEXT_TASK_DELAY_MINUTES (+ jitter), task N+1 becomes
#      visible and a "here's your next brief" email lands in the work inbox.
#   2. After TASK_FEEDBACK_DELAY_MINUTES (+ jitter), the mentor's feedback
#      email on task N lands (larger delay — student is already at work
#      on the new task, which is the point).
#
# Set the next-task delay SHORTER than the feedback delay so the next
# brief arrives first. This mirrors real internships: mentor hands you
# the next thing on their own schedule, then writes up notes on the
# previous work a bit later. Students learn to use the feedback to
# strengthen the task they're currently working on.
#
# Suggested "authentic" values:
#   TASK_NEXT_TASK_DELAY_MINUTES=20
#   TASK_NEXT_TASK_DELAY_JITTER_MINUTES=10
#   TASK_FEEDBACK_DELAY_MINUTES=120            # ~2 hours
#   TASK_FEEDBACK_DELAY_JITTER_MINUTES=60
TASK_NEXT_TASK_DELAY_MINUTES=0
TASK_NEXT_TASK_DELAY_JITTER_MINUTES=0
TASK_FEEDBACK_DELAY_MINUTES=0
TASK_FEEDBACK_DELAY_JITTER_MINUTES=0

# --- Admin / debug endpoints ---
# A shared bearer token used by the workready-portal admin.html page to
# inspect and manipulate student state for testing. Leave blank in
# production to disable the /api/v1/admin/* endpoints entirely.
# Generate a random one with: python -c 'import secrets; print(secrets.token_urlsafe(24))'
WORKREADY_ADMIN_TOKEN=
